OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...
NETDATA_BASE_URL=http://netdata:19999
LOG_PATH=/host/logs/auth.log

# Cadence: either daily at REPORT_HOUR (default), or every N hours.
# If REPORT_INTERVAL_HOURS is set, REPORT_HOUR is ignored.
REPORT_HOUR=8
# REPORT_INTERVAL_HOURS=6

# Interactive Q&A: comma-separated Telegram user IDs allowed to chat
# with the bot. Leave empty to disable Q&A (digest still publishes).
# Find your user ID by messaging @userinfobot.
TELEGRAM_AUTHORIZED_USERS=

# Optional separate chat for critical events. When set, critical findings
# AND real-time CRITICAL Netdata alarms (polled every 60s) get duplicated
# here in addition to the routine digest channel. Leave empty to disable.
TELEGRAM_CRITICAL_CHAT_ID=

# Quiet hours window (server local time, 0-23). During the window,
# routine digests are suppressed but critical events still go through.
# Format: START-END, supports midnight wrap. Empty = always allowed.
# Example: 22-7 silences digests from 22:00 until 07:00 the next morning.
QUIET_HOURS=

# Security scan: set to true once and redeploy to re-baseline against current
# host state (do this after legitimate changes like adding an SSH key). Then
# set back to false and redeploy.
RESET_BASELINE=false

# ──────────────────────────────────────────────────────────────────────
# Voice summary (/speak)
# ──────────────────────────────────────────────────────────────────────
# Routes through the same OpenRouter API key as the chat completions —
# no separate provider account needed.
#
# Models (set TTS_MODEL):
#   openai/gpt-4o-mini-tts-2025-12-15   (~$0.60/M chars, OpenAI voices) ← default
#   mistralai/voxtral-mini-tts-2603     (~$16/M chars, voice cloning)
#   google/gemini-3.1-flash-tts-preview (multilingual, 70+ languages)
TTS_MODEL=openai/gpt-4o-mini-tts-2025-12-15

# Voice name. Catalog depends on TTS_MODEL — for OpenAI's TTS:
# alloy, nova, shimmer, echo, fable, onyx (check OpenRouter model page
# for other providers' voice IDs).
TTS_VOICE=alloy

# When true, transcode MP3 → OGG-Opus via ffmpeg and send as a Telegram
# voice message (round avatar + waveform UI). Requires ffmpeg in image.
# When false, send the raw MP3 as a regular audio attachment — no
# ffmpeg dependency, but a less polished UI.
TTS_AS_VOICE_MESSAGE=true

# Cost guardrail — characters of input text passed to the TTS endpoint.
# Output text is truncated at the last sentence boundary below this cap.
TTS_MAX_CHARS=3000

# Playback speed multiplier. 1.0 = normal. Some models ignore this.
TTS_SPEED=1.0
